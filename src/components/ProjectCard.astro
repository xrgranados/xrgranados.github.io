---
// src/components/ProjectCard.astro
import type { Project } from '@data/portfolio';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const { type, name, subtitle, description, achievements, stack, badge, personal } = project;

const badgeColors = {
  orange: { bg: 'rgba(245,166,35,0.1)', border: 'rgba(245,166,35,0.3)', color: 'var(--accent3)' },
  blue:   { bg: 'rgba(91,200,245,0.05)', border: 'rgba(91,200,245,0.3)', color: 'var(--accent2)' },
};
const badgeStyle = badge ? badgeColors[badge.color] : null;
---

<article class:list={['project-card', { personal }]}>
  <header class="project-header">
    <div class="project-meta">
      <p class:list={['project-type', { 'type-blue': personal }]}>{type}</p>
      <h3 class="project-name">{name}</h3>
      <p class="project-sub">{subtitle}</p>
    </div>

    {badge && badgeStyle && (
      <span
        class="badge"
        style={`background:${badgeStyle.bg}; border:1px solid ${badgeStyle.border}; color:${badgeStyle.color}`}
        aria-label={badge.text}
      >
        {badge.text}
      </span>
    )}
  </header>

  <div class="project-body">
    <p class="project-desc">{description}</p>
    <ul class="project-achievements" aria-label="Key achievements">
      {achievements.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </div>

  <footer class="project-footer" aria-label="Technologies used">
    {stack.map((tech) => (
      <span class="tech-tag">{tech}</span>
    ))}
  </footer>
</article>

<style>
  .project-card {
    background: var(--bg);
    border: 1px solid var(--border);
    overflow: hidden;
    transition: border-color 0.3s, transform 0.2s;
  }
  .project-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .project-card.personal {
    border-left: 3px solid var(--accent2);
  }

  /* Header */
  .project-header {
    padding: 24px 28px 16px;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
  }

  .project-meta { flex: 1; }

  .project-type {
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--accent3);
    text-transform: uppercase;
    margin-bottom: 8px;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .project-type::before { content: '▶'; font-size: 8px; }
  .project-type.type-blue { color: var(--accent2); }

  .project-name {
    font-family: var(--font-serif);
    font-size: 20px;
    font-weight: 600;
    margin-bottom: 8px;
    color: var(--text);
  }

  .project-sub {
    font-size: 12px;
    color: var(--text2);
  }

  .badge {
    font-size: 9px;
    letter-spacing: 2px;
    padding: 5px 12px;
    text-transform: uppercase;
    flex-shrink: 0;
    align-self: flex-start;
    font-family: var(--font-mono);
  }

  /* Body */
  .project-body { padding: 24px 28px; }

  .project-desc {
    color: var(--text2);
    font-size: 12.5px;
    line-height: 1.9;
    margin-bottom: 20px;
  }

  .project-achievements {
    list-style: none;
    margin-bottom: 20px;
  }
  .project-achievements li {
    color: var(--text2);
    font-size: 12px;
    line-height: 1.8;
    padding: 5px 0;
    border-bottom: 1px solid var(--border);
    display: flex;
    align-items: baseline;
    gap: 10px;
  }
  .project-achievements li:last-child { border-bottom: none; }
  .project-achievements li::before {
    content: '//';
    color: var(--accent);
    font-size: 10px;
    flex-shrink: 0;
  }

  /* Footer */
  .project-footer {
    padding: 16px 28px;
    background: var(--surface2);
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
    border-top: 1px solid var(--border);
  }

  .tech-tag {
    font-size: 10px;
    padding: 3px 10px;
    border: 1px solid var(--border2);
    color: var(--muted);
    letter-spacing: 1px;
  }
</style>
