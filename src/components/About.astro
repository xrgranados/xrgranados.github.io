---
// src/components/About.astro
import { about, skillGroups } from '@data/portfolio';
---

<section id="about" aria-labelledby="about-heading">
  <div class="section-wrap">
    <div class="section-header">
      <span class="section-num">01</span>
      <h2 class="section-title" id="about-heading" data-matrix>About Me</h2>
      <div class="section-line"></div>
    </div>

    <div class="about-grid">
      <!-- Bio -->
      <div class="about-text">
        <p class="about-headline" data-matrix set:html={about.headline.replace('web applications', '<span>web applications</span>')}></p>
        {about.paragraphs.map((p) => (
          <p set:html={p} data-matrix></p>
        ))}
      </div>

      <!-- Stack Panel -->
      <aside class="stack-panel" aria-label="Technology stack">
        <div class="stack-panel-header" data-matrix>▶ Tech Stack</div>
        {skillGroups.map(({ label, chips }) => (
          <div class="stack-group">
            <p class="stack-group-label">{label}</p>
            <ul class="stack-chips" role="list">
              {chips.map(({ name, primary }) => (
                <li>
                  <span class:list={['chip', { 'chip-primary': primary }]} data-matrix>{name}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </aside>
    </div>
  </div>
</section>

<style>
  section {
    position: relative;
    z-index: 1;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 48px;
    align-items: start;
  }

  /* Bio */
  .about-text p {
    color: var(--text2);
    font-size: 13px;
    line-height: 2;
    margin-bottom: 20px;
  }
  .about-text :global(strong) { color: var(--text); }
  .about-text :global(em)     { color: var(--accent); font-style: normal; }

  .about-headline {
    font-family: var(--font-serif);
    font-size: 28px;
    font-weight: 300;
    font-style: italic;
    line-height: 1.3;
    margin-bottom: 24px;
    color: var(--text);
  }
  .about-headline :global(span) { color: var(--accent); }

  /* Stack panel */
  .stack-panel {
    background: var(--surface);
    border: 1px solid var(--border);
  }

  .stack-panel-header {
    background: var(--surface2);
    border-bottom: 1px solid var(--border);
    padding: 12px 20px;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--accent);
    text-transform: uppercase;
  }

  .stack-group {
    padding: 20px;
    border-bottom: 1px solid var(--border);
  }
  .stack-group:last-child { border-bottom: none; }

  .stack-group-label {
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--muted);
    text-transform: uppercase;
    margin-bottom: 12px;
  }

  .stack-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    list-style: none;
  }

  .chip {
    padding: 4px 12px;
    border: 1px solid var(--border2);
    font-size: 11px;
    color: var(--text2);
    transition: all 0.2s;
    display: inline-block;
  }
  .chip:hover { border-color: var(--accent); color: var(--accent); }
  .chip-primary {
    border-color: var(--accent);
    color: var(--accent);
    background: var(--accent-dim);
  }

  @media (max-width: 768px) {
    .about-grid { grid-template-columns: 1fr; }
  }
</style>
