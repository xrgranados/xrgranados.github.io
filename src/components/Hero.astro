---
// src/components/Hero.astro
import { meta, stats } from '@data/portfolio';
---

<section id="hero" aria-label="Introduction">
  <div class="hero-inner">
    <div class="hero-left">
      <p class="hero-eyebrow" data-matrix>Hi! I'm Rafael</p>
      <h1 class="hero-name" data-matrix>{meta.name}</h1>
      <p class="hero-title" data-matrix>{meta.role}<span class="cursor" aria-hidden="true"></span></p>
      <p class="hero-desc" data-matrix>{meta.tagline}</p>

      <div class="hero-cta">
        <a href="#work"    class="btn btn-primary" data-matrix> ▶ View my work</a>
        <a href="#contact" class="btn btn-outline" data-matrix>Get in touch →</a>
      </div>

      <div class="hero-stats" role="list" aria-label="Quick stats">
        {stats.map(({ value, label }) => (
          <div class="stat" role="listitem">
            <span class="stat-num" data-matrix>{value}</span>
            <span class="stat-label" data-matrix>{label}</span>
          </div>
        ))}
      </div>
    </div>

    <!-- Photo -->
    <div class="hero-photo-wrap" aria-hidden="true">
      <div class="hero-photo">
        <img src="/images/photo.jpg" alt={meta.photoAlt} width="220" />
        <!--
          Replace this div with:
          and place your photo in /public/images/photo.jpg
        -->
        <!-- <span class="photo-placeholder">[ YOUR PHOTO ]</span> -->
        <div class="photo-border"></div>
        <span class="photo-tag" data-matrix>{meta.name}</span>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: 100px 80px 80px;
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 80px;
    align-items: center;
    width: 100%;
  }

  .hero-left > * {
    animation: fadeUp 0.6s ease both;
  }
  .hero-eyebrow { animation-delay: 0.1s; }
  .hero-name    { animation-delay: 0.2s; }
  .hero-title   { animation-delay: 0.3s; }
  .hero-desc    { animation-delay: 0.4s; }
  .hero-cta     { animation-delay: 0.5s; }
  .hero-stats   { animation-delay: 0.6s; }

  .hero-eyebrow {
    font-size: 11px;
    letter-spacing: 4px;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 12px;
  }
  .hero-eyebrow::before {
    content: '';
    display: block;
    width: 24px;
    height: 1px;
    background: var(--accent);
  }

  .hero-name {
    font-family: var(--font-serif);
    font-size: clamp(42px, 5vw, 64px);
    font-weight: 600;
    line-height: 1.0;
    margin-bottom: 8px;
    letter-spacing: -1px;
  }

  .hero-title {
    font-family: var(--font-serif);
    font-size: clamp(36px, 4vw, 54px);
    font-weight: 300;
    font-style: italic;
    color: var(--accent);
    margin-bottom: 28px;
    line-height: 1.1;
  }

  .cursor {
    display: inline-block;
    width: 2px;
    height: 0.9em;
    background: var(--accent);
    margin-left: 2px;
    vertical-align: text-bottom;
    animation: blink 1s step-end infinite;
  }

  .hero-desc {
    color: var(--text2);
    font-size: 13px;
    line-height: 1.9;
    max-width: 480px;
    margin-bottom: 40px;
    border-left: 2px solid var(--border2);
    padding-left: 20px;
  }

  .hero-cta {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }

  /* Stats */
  .hero-stats {
    display: flex;
    border: 1px solid var(--border);
    margin-top: 48px;
    animation: fadeUp 0.6s 0.6s ease both;
  }

  .stat {
    flex: 1;
    padding: 20px 24px;
    border-right: 1px solid var(--border);
    text-align: center;
  }
  .stat:last-child { border-right: none; }

  .stat-num {
    font-family: var(--font-serif);
    font-size: 32px;
    font-weight: 600;
    color: var(--accent);
    display: block;
    line-height: 1;
    margin-bottom: 6px;
  }
  .stat-label {
    font-size: 10px;
    color: var(--muted);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  /* Photo */
  .hero-photo-wrap {
    animation: fadeUp 0.6s 0.4s ease both;
    position: relative;
    flex-shrink: 0;
  }

  .hero-photo {
    width: 220px;
    height: 245px;
    border: 1px solid var(--border2);
    background: var(--surface2);
    position: relative;
    overflow: visible;
  }
  .hero-photo::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--accent-dim), transparent);
    z-index: 1;
  }

  .photo-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--muted);
    z-index: 2;
  }

  .photo-border {
    position: absolute;
    width: 100%;
    height: 100%;
    border: 1px solid var(--accent);
    transform: translate(10px, 10px);
    pointer-events: none;
    z-index: -1;
    top: 0;
    left: 0;
  }

  .photo-tag {
    position: absolute;
    bottom: 0;
    left: 0; right: 0;
    background: var(--accent);
    color: var(--bg);
    font-size: 9px;
    letter-spacing: 2px;
    text-align: center;
    padding: 5px;
    font-weight: 700;
    text-transform: uppercase;
    z-index: 3;
  }

  @media (max-width: 768px) {
    section {
      padding: 90px 24px 60px;
      min-height: auto;
    }
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 40px;
    }
    .hero-photo { width: 160px; height: 190px; }
    .hero-stats {
      flex-direction: column;
    }
    .stat {
      border-right: none;
      border-bottom: 1px solid var(--border);
    }
    .stat:last-child { border-bottom: none; }
  }
</style>
