---
// src/components/Work.astro
import { projects } from '@data/portfolio';
import ProjectCard from '@components/ProjectCard.astro';
---

<section id="work" aria-labelledby="work-heading">
  <div class="section-wrap">
    <div class="section-header">
      <span class="section-num">02</span>
      <h2 class="section-title" id="work-heading" data-matrix>Work & Projects</h2>
      <div class="section-line"></div>
    </div>

    <div class="nda-note" role="note">
      <p class="nda-label" data-matrix>▶ A note on confidentiality</p>
      <p data-matrix>
        Most of my professional work is under NDA. The projects below are presented as
        <strong>case studies</strong> — describing the technical challenges I solved without
        revealing client names or sensitive details. This is standard practice in professional
        development portfolios.
      </p>
    </div>

    <div class="projects-grid">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  </div>
</section>

<style>
  section {
    background: var(--surface);
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    position: relative;
    z-index: 1;
  }

  .nda-note {
    border: 1px solid var(--border2);
    background: linear-gradient(135deg, var(--accent-dim), transparent);
    padding: 24px 28px;
    margin-bottom: 24px;
  }
  .nda-label {
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--accent);
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .nda-note p:last-child {
    color: var(--text2);
    font-size: 12.5px;
    line-height: 1.8;
  }
  .nda-note :global(strong) { color: var(--text); }

  .projects-grid {
    display: grid;
    gap: 24px;
  }
</style>
